    "- \u1005\u102c\u101e\u102c\u1038\u1011\u102f\u1010\u103a\u1015\u1031\u1038\u101e\u1031\u102c \u1019\u1031\u102c\u103a\u1012\u101a\u103a\u1019\u103b\u102c\u1038- (LLM \u1019\u103b\u102c\u1038\u101f\u102f\u101c\u100a\u103a\u1038 \u1001\u1031\u102b\u103a\u101e\u100a\u1037\u103a) \u1021\u1000\u103c\u102e\u1038\u1005\u102c\u1038 \u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038 \u1019\u1031\u102c\u103a\u1012\u101a\u103a\u1019\u103b\u102c\u1038\u101e\u100a\u103a \u1000\u103b\u103d\u1014\u103a\u102f\u1015\u103a\u1010\u102d\u102f\u1037\u1014\u1031\u1037\u1005\u1009\u103a\u1015\u103c\u1031\u102c\u1006\u102d\u102f\u1014\u1031\u101e\u1031\u102c \u1018\u102c\u101e\u102c\u1005\u1000\u102c\u1038\u1010\u103d\u1004\u103a \u1010\u103d\u1031\u1037\u101b\u101e\u1000\u1032\u1037\u101e\u102d\u102f\u1037 \u1015\u102f\u1036\u1019\u103e\u1014\u103a\u101e\u102f\u1036\u1038\u1014\u103e\u102f\u1014\u103a\u1038\u1015\u103c\u1031\u102c\u1006\u102d\u102f\u101e\u100a\u1037\u103a \u1005\u1000\u102c\u1038\u1021\u1005\u102e\u1021\u1005\u1009\u103a\u1019\u103b\u102c\u1038\u1000\u102d\u102f \u1001\u1014\u1037\u103a\u1019\u103e\u1014\u103a\u1038\u1014\u102d\u102f\u1004\u103a\u1005\u1031\u101b\u1014\u103a \u1005\u102c\u101e\u102c\u1038\u1015\u1019\u102c\u100f \u1019\u103c\u1031\u102c\u1000\u103a\u1019\u103c\u102c\u1038\u1005\u103d\u102c\u1016\u103c\u1004\u1037\u103a \u101c\u1031\u1037\u1000\u103b\u1004\u1037\u103a\u1015\u1031\u1038\u1011\u102c\u1038\u101e\u100a\u1037\u103a \u1019\u1031\u102c\u103a\u1012\u101a\u103a\u1019\u103b\u102c\u1038\u1016\u103c\u1005\u103a\u1015\u102b\u101e\u100a\u103a\u104b \u1005\u102d\u1005\u1005\u103a\u1006\u102f\u1036\u1038\u1016\u103c\u1010\u103a\u1014\u102d\u102f\u1004\u103a\u101b\u1014\u103a \u1000\u103d\u1014\u103a\u1015\u103b\u1030\u1010\u102c\u1021\u102c\u1038 \u101c\u1031\u1037\u101c\u102c\u101e\u1004\u103a\u101a\u1030\u1005\u1031\u1001\u103c\u1004\u103a\u1038\u1014\u103e\u1004\u1037\u103a \u1019\u1031\u102c\u103a\u1012\u101a\u103a\u1019\u103b\u102c\u1038\u1000\u10